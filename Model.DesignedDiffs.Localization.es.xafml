        <Member Name="IsAvailableInPos" Caption="Disponible en TPV" />
        <Member Name="IsAvailableInPurchases" Caption="Disponible en compras" />
        <Member Name="IsAvailableInSales" Caption="Disponible en ventas" />
        <Member Name="Name" Caption="Descripción" />
        <Member Name="Notes" Caption="Notas" />
        <Member Name="Picture" Caption="Imagen" />
        <Member Name="Pictures" Caption="Imágenes" />
        <Member Name="PriceList" Caption="Precio de venta" />
        <Member Name="PurchaseAccount" Caption="Cuenta de compras" />
        <Member Name="PurchaseTaxes" Caption="Impuestos en compras" />
        <Member Name="SalesAccount" Caption="Cuenta de ventas" />
        <Member Name="SalesTaxes" Caption="Impuestos en ventas" />
        <Member Name="StandardCost" Caption="Precio de compra" />
