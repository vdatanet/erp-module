        <Member Name="Notes" Caption="Notas" />
        <Member Name="ParentCategory" Caption="Categoría superior" />
        <Member Name="Products" Caption="Productos" />
        <Member Name="Subcategories" Caption="Subcategorías" />
      </OwnMembers>
    </Class>
    <Class Name="erp.Module.BusinessObjects.Products.Product" Caption="Producto">
      <OwnMembers>
        <Member Name="Attachments" Caption="Archivos" />
        <Member Name="Barcode" Caption="Código de barras" />
