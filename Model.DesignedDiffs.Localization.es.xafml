  <Views>
    <DetailView Id="Category_DetailView">
      <Layout>
        <LayoutGroup Id="Main">
          <LayoutGroup Id="SimpleEditors">
            <LayoutGroup Id="Category" Caption="Categoría">
              <LayoutGroup Id="Category_col2" Caption="Category_col2" />
