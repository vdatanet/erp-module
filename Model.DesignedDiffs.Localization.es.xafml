        <Member Name="Name" Caption="Nombre" />
        <Member Name="Notes" Caption="Notas" />
      </OwnMembers>
    </Class>
    <Class Name="erp.Module.BusinessObjects.Invoicing.Invoice" Caption="Factura">
      <OwnMembers>
        <Member Name="Customer" Caption="Cliente" />
        <Member Name="InvoiceDate" Caption="Fecha Factura" />
